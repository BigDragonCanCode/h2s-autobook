# Copy this file to `.env` and fill in your local settings.

H2S_EMAIL=your-email@example.com
H2S_PASSWORD=your-password

# ── 共享邮件服务（Resend） ───────────────────────────────────────────
# 启用后，使用共享邮件服务发送新房源和预订成功通知。
# RESEND_FROM 必须是 Resend 已验证域名下的邮箱，否则 API 直接 403。
SHARED_EMAIL_ENABLED=true
RESEND_API_KEY=
RESEND_FROM=notify@example.com
NOTIFY_EMAIL_TO=your-email@example.com

SOURCES=holland2stay
CITIES=Rotterdam,25
AVAILABILITY_FILTERS=Available to book,179
CHECK_INTERVAL=60
JITTER_RATIO=0.20
LOG_LEVEL=INFO
AUTO_BOOK_ENABLED=true
AUTO_BOOK_DRY_RUN=false
AUTO_BOOK_CANCEL_ENABLED=false
AUTO_BOOK_PAYMENT_METHOD=idealcheckout_visa
AUTO_BOOK_MAX_RENT=1300
AUTO_BOOK_ALLOWED_TYPES=Studio
# Deprecated for H2S list filtering; prefer AUTO_BOOK_ALLOWED_OFFER.
# AUTO_BOOK_ALLOWED_CONTRACTS=Indefinite
# Empty means long-stay / no offer_text_two. Use Short-stay for short-stay only.
AUTO_BOOK_ALLOWED_OFFER=
AUTO_BOOK_ALLOWED_BUILDINGS=
MONITOR_RANGE_START=2026-07-01
MONITOR_RANGE_END=2026-07-28

# Use a manually verified real Chrome session for H2S scraping.
# Start Chrome with:
# /usr/bin/google-chrome --remote-debugging-port=9222 --user-data-dir=/tmp/h2s-real-chrome
H2S_USE_REAL_CHROME_CDP=false
H2S_CDP_URL=http://127.0.0.1:9222

# Optional: print the exact filter-reject reason for each listing during debugging.
H2S_FILTER_DEBUG=false
