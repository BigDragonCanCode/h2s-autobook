# Copy this file to `.env` and fill in your local settings.

H2S_EMAIL=your-email@example.com
H2S_PASSWORD=your-password

# ── 共享邮件服务（Resend） ───────────────────────────────────────────
# 启用后，使用共享邮件服务发送新房源和预订成功通知。
# RESEND_FROM 必须是 Resend 已验证域名下的邮箱，否则 API 直接 403。
SHARED_EMAIL_ENABLED=true
RESEND_API_KEY=
RESEND_FROM=notify@example.com
NOTIFY_EMAIL_TO=your-email@example.com

SOURCES=holland2stay
CITIES=Rotterdam,25
